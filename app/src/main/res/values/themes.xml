<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SmartMunicipalApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        
        <!-- Background colors. -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        
        <!-- Text colors -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        
        <!-- Form elements -->
        <item name="colorError">@color/error_color</item>
    </style>
</resources>
